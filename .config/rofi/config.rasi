/* Main Config 1440p */

@import "~/.config/rofi/master-config.rasi" 

/* ---- Configuration ---- */
configuration {
	font:	"0xProto Nerd Font 11";
}
/* ---- Window ---- */
window {
    width:	40%;
}

/* ---- Entry input ---- */
entry {
    width:	18%;
}

/* ---- Listview ---- */
listview {
    lines:	8;
}

/* ---- Mode Switcher ---- */
button {
    width:	110px;
}

element-text {
    font:	"0xProto Nerd Font 14";
}

