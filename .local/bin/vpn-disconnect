#!/bin/bash
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"

active=$(wg show interfaces 2>/dev/null)
if [ -z "$active" ]; then
  notify-send -t 4000 "ProtonVPN" "Already disconnected"
  exit 0
fi

CONF_DIR="$HOME/.config/protonvpn/wireguard"
failed=false
for a in $active; do
  sudo -n resolvectl revert "$a" 2>/dev/null
  conf="$CONF_DIR/$a.conf"
  if [ ! -f "$conf" ]; then
    conf="$a"
  fi
  if ! sudo -n wg-quick down "$conf" 2>/dev/null; then
    failed=true
  fi
done

sudo -n resolvconf -u 2>/dev/null || true

if $failed; then
  notify-send -t 8000 "ProtonVPN" "Failed to disconnect. Try: More → Setup WireGuard Sudo"
else
  notify-send -t 4000 "ProtonVPN" "Disconnected"
fi
